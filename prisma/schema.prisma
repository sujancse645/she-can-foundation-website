generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Contact {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  email     String
  phone     String
  subject   String
  message   String
  createdAt DateTime @default(now())
}

model Volunteer {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  name         String
  email        String
  phone        String
  skills       String
  availability String
  resume       String?
  message      String?
  createdAt    DateTime @default(now())
}

model Donation {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  donorName     String
  amount        Float
  paymentStatus String   @default("pending") // pending, completed, failed
  createdAt     DateTime @default(now())
}

model Campaign {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  title        String
  description  String
  image        String?
  goalAmount   Float
  raisedAmount Float    @default(0)
  createdAt    DateTime @default(now())
}

model Blog {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  title     String
  slug      String   @unique
  content   String
  image     String?
  category  String
  createdAt DateTime @default(now())
}

model Event {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  description String
  location    String
  date        DateTime
  createdAt   DateTime @default(now())
}

model Newsletter {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String   @unique
  createdAt DateTime @default(now())
}
